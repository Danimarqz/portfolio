---
import type TranslationMessages from "@/types.d.ts"

interface Props {
  m: TranslationMessages
}

const { m } = Astro.props

// whoami output. Name/stack are language-agnostic; role/focus/loc come from i18n.
const rows = [
  { label: "name", value: "Daniel Márquez", cls: "text-[var(--color-fg)]" },
  { label: "role", value: m.hero_role, cls: "text-[var(--color-cyan)]" },
  { label: "focus", value: m.hero_focus, cls: "text-[var(--color-green)]" },
  { label: "stack", value: "Go · Python · Bedrock · Lambda · DynamoDB", cls: "text-[var(--color-muted)]" },
  { label: "loc", value: m.hero_loc, cls: "text-[var(--color-muted)]" },
]
---

<div class="max-w-2xl mx-auto">
  <p class="flex items-center gap-2 mb-4 font-mono text-sm text-[var(--color-dim)]">
    <span class="size-2 rounded-full bg-[var(--color-green)] animate-pulse"></span>
    {m.available}
  </p>

  <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden shadow-2xl shadow-black/40">
    <!-- title bar -->
    <div class="flex items-center gap-2 px-4 py-2.5 bg-[var(--color-surface-bar)] border-b border-[var(--color-border)]">
      <span class="size-3 rounded-full bg-[#ff5f56]"></span>
      <span class="size-3 rounded-full bg-[#ffbd2e]"></span>
      <span class="size-3 rounded-full bg-[#27c93f]"></span>
      <span class="ml-2 font-mono text-xs text-[var(--color-dim)] truncate">dani@danimarqz: ~</span>
    </div>

    <!-- body -->
    <div id="term" class="p-4 sm:p-6 font-mono text-sm sm:text-[15px] leading-relaxed">
      <p class="text-[var(--color-fg-soft)] break-words">
        <span class="text-[var(--color-green)]">$</span>
        <span id="term-cmd" data-cmd="whoami --full"></span><span id="term-cursor" class="text-[var(--color-cyan)]">▋</span>
      </p>

      <dl id="term-out" class="mt-3 space-y-1">
        {rows.map((r) => (
          <div class="out-row flex gap-3 sm:gap-4 break-words">
            <dt class="text-[var(--color-dimmer)] w-12 shrink-0">{r.label}</dt>
            <dd class={`${r.cls} min-w-0`}>{r.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</div>

<style>
  #term-cursor { animation: blink 1.1s step-end infinite; }
  @keyframes blink { 50% { opacity: 0; } }
</style>

<script>
  function runTerminal() {
    const cmdEl = document.getElementById("term-cmd");
    const cursor = document.getElementById("term-cursor");
    const rows = Array.from(document.querySelectorAll<HTMLElement>("#term-out .out-row"));
    if (!cmdEl) return;
    const cmd = cmdEl.dataset.cmd || "";
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const revealRows = () => {
      rows.forEach((row, i) => {
        row.style.opacity = "0";
        row.style.transform = "translateY(4px)";
        row.style.transition = "opacity .35s ease, transform .35s ease";
        setTimeout(() => {
          row.style.opacity = "1";
          row.style.transform = "none";
        }, 120 * i);
      });
    };

    if (reduced) {
      cmdEl.textContent = cmd;
      if (cursor) cursor.style.display = "none";
      return; // rows already visible
    }

    // hide rows until the command finishes typing
    rows.forEach((r) => (r.style.opacity = "0"));

    let i = 0;
    const type = () => {
      if (i <= cmd.length) {
        cmdEl.textContent = cmd.slice(0, i);
        i++;
        setTimeout(type, 70 + (Math.random() * 50 - 25));
      } else {
        setTimeout(revealRows, 250);
      }
    };
    type();
  }

  document.addEventListener("astro:page-load", runTerminal);
</script>
