---
import type { ProjectIcon, ProjectStatus } from "@/data/projects"

interface Props {
  icon: ProjectIcon
  status: ProjectStatus
  statusLabel: string
  title: string
  description: string
  stack: string[]
  href?: string
}

const { icon, status, statusLabel, title, description, stack, href } = Astro.props

// Inline icon paths (Lucide-style), stroked with currentColor. aria-hidden — decorative.
const ICONS: Record<ProjectIcon, string> = {
  bolt: '<path d="M13 2 3 14h7l-1 8 10-12h-7z"/>',
  robot: '<rect x="4" y="8" width="16" height="12" rx="2"/><path d="M12 8V4M8 2h8"/><circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/>',
  wallet: '<path d="M3 7a2 2 0 0 1 2-2h14a1 1 0 0 1 1 1v3"/><path d="M3 7v10a2 2 0 0 0 2 2h14a1 1 0 0 0 1-1v-3"/><path d="M16 12h5v4h-5a2 2 0 0 1 0-4z"/>',
  server: '<rect x="3" y="4" width="18" height="7" rx="1"/><rect x="3" y="13" width="18" height="7" rx="1"/><circle cx="7" cy="7.5" r="0.6"/><circle cx="7" cy="16.5" r="0.6"/>',
  code: '<path d="m8 18-6-6 6-6"/><path d="m16 6 6 6-6 6"/>',
}

const Tag = href ? "a" : "div"
---

<Tag
  href={href}
  {...href ? { target: "_blank", rel: "noopener noreferrer" } : {}}
  class="group flex flex-col gap-3 p-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/60 transition hover:border-[var(--color-cyan)] hover:-translate-y-0.5"
>
  <div class="flex items-center justify-between">
    <svg
      class="size-7 text-[var(--color-cyan)]"
      viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"
      aria-hidden="true" set:html={ICONS[icon]}
    />
    <span
      class:list={[
        "font-mono text-xs px-2 py-0.5 rounded-full border",
        status === "production"
          ? "text-[var(--color-green)] border-[var(--color-green)]/40"
          : "text-[var(--color-dim)] border-[var(--color-border-subtle)]",
      ]}
    >
      {status === "production" ? "● " : ""}{statusLabel}
    </span>
  </div>

  <h3 class="text-lg text-[var(--color-fg)] font-medium">{title}</h3>
  <p class="text-sm text-[var(--color-muted)] leading-relaxed flex-1">{description}</p>
  <p class="font-mono text-xs text-[var(--color-dim)]">{stack.join(" · ")}</p>
</Tag>
