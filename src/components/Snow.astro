---
// Subtle ambient snow behind all content. Low density, slow drift. Never the protagonist.
---
<canvas id="snow" aria-hidden="true"></canvas>

<style>
  #snow {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    display: block;
  }
</style>

<script>
  // ponytail: vanilla canvas, no animation lib. Density ~1 flake / 20px width, opacity ~0.4.
  function startSnow() {
    const canvas = document.getElementById("snow") as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let w = 0, h = 0, flakes: { x: number; y: number; r: number; vy: number; drift: number; phase: number }[] = [];
    let raf = 0;

    const resize = () => {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
      const count = Math.round(w / 20);
      flakes = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: 0.6 + Math.random() * 1.4,
        vy: 0.15 + Math.random() * 0.35,
        drift: 0.3 + Math.random() * 0.6,
        phase: Math.random() * Math.PI * 2,
      }));
    };

    const draw = () => {
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = "rgba(244, 248, 253, 0.4)";
      for (const f of flakes) {
        f.y += f.vy;
        f.phase += 0.01;
        f.x += Math.sin(f.phase) * f.drift * 0.3;
        if (f.y > h + 2) { f.y = -2; f.x = Math.random() * w; }
        ctx.beginPath();
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
        ctx.fill();
      }
      raf = requestAnimationFrame(draw);
    };

    resize();
    window.addEventListener("resize", resize);

    if (reduced) {
      // Draw one static frame, no animation.
      ctx.fillStyle = "rgba(244, 248, 253, 0.4)";
      for (const f of flakes) {
        ctx.beginPath();
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
        ctx.fill();
      }
      return;
    }

    raf = requestAnimationFrame(draw);
    document.addEventListener("astro:before-swap", () => cancelAnimationFrame(raf), { once: true });
  }

  document.addEventListener("astro:page-load", startSnow);
</script>
